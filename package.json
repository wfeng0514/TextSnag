{
  "name": "textsnag",
  "displayName": "TextSnag",
  "version": "1.0.0",
  "description": "Click, select, copy — extract text from any webpage region with a simple drag.",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "plasmo dev",
    "dev:firefox": "plasmo dev --target=firefox-mv2",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv2",
    "package": "plasmo package",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "plasmo": "0.90.5",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "activeTab",
      "scripting",
      "clipboardWrite",
      "storage"
    ]
  }
}
